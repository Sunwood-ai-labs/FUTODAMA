# Claude Code を GLM (z.ai Anthropic-compatible API) で動かすための設定
# 実運用では .env にコピーして ANTHROPIC_AUTH_TOKEN を実値に置き換えてください

# Anthropic-compatible API 接続先 / 認証
ANTHROPIC_BASE_URL="https://api.z.ai/api/anthropic"
ANTHROPIC_AUTH_TOKEN="your-token-here"

# モデル選択（Claude Code が利用するデフォルトモデル）
ANTHROPIC_DEFAULT_HAIKU_MODEL="glm-4.5-air"
ANTHROPIC_DEFAULT_SONNET_MODEL="glm-5"
ANTHROPIC_DEFAULT_OPUS_MODEL="glm-5"

# 外部サービス連携トークン
# Cloudflare Workers 操作用 API トークン
CLOUDFLARE_API_TOKEN="your-cloudflare-workers-api-token"
# GitHub API / Git 操作用 Personal Access Token
GITHUB_PAT="your-github-pat"
